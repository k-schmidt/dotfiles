# Set proxy for Meta devvms (no-op on macOS where github.com resolves directly)
if [ "$(uname)" = "Linux" ] && ! host github.com >/dev/null 2>&1; then
  export http_proxy=http://fwdproxy:8080
  export https_proxy=http://fwdproxy:8080
fi

# If ~/.bashrc exists, load it (keeps Bash consistent across shells)
if [ -f ~/.bashrc ]; then
  source ~/.bashrc
fi